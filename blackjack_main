from assets.art import logo
import random

def add_card():
    possible_cards = [11, 2, 3, 4, 5, 6, 7, 8, 9, 10, 10, 10, 10]
    return random.choice(possible_cards)

def scoring(hand:list):
    total = sum(hand)
    ace_count = sum(1 for card in hand if card == 11)

    if total == 21 and len(hand) == 2:
        total = 0

    if ace_count > 0 and total > 21:
        total -= 10
        ace_count -= 1

    return total

def results(my_score:int, comp_score:int):
    # check for blackjacks on either side first and then for bust
    # lastly, if the user doesn't want to proceed forward
    if my_score > 21:
        print("You went over 21, it's a bust! You lose 😢")
    elif comp_score > 21:
        print("Computer went over 21! You win automatically 🤩")
    elif comp_score == 0:
        print("Computer has a Blackjack, it won! 🥲")
    elif my_score == 0:
        print("You have a Blackjack you win! ⭐️🏆")
    elif my_score > comp_score:
        print("You win 🥇")
    elif my_score < comp_score:
        print("You lose 😤")
    elif my_score == comp_score:
        print("It's a tie!")


